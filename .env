# URL destiny
BASE_URL=https://publico.oefa.gob.pe
SEARCH_PATH=/repdig/consulta/consultaTfa.xhtml

# Scraper config
DELAY_BETWEEN_REQUESTS_MS=200
REQUEST_TIMEOUT_MS=20000

# Error 429 backoff
RETRY_MAX_RETRIES=5
RETRY_BASE_DELAY_MS=1000
RETRY_MAX_DELAY_MS=30000

# Logging
DEBUG=true

# Límite de Paginas: (1,2,3, ... etc o escribir "full" para ejecutar y descargar todas las páginas)
MAX_PAGES=3